{
  "version": 2,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/admin/(.*\\.php)",
      "dest": "/admin/$1"
    },
    {
      "src": "/admin",
      "dest": "/admin/login.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}